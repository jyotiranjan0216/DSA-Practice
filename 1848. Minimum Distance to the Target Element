class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) {
        int size = nums.size();
        int iteration = min(abs(size- start), abs(start-0));
        int rest = ((size/2) > start)? size: 0;
        for(int i =0; i < iteration; i++) {
            if(nums[start-i] == target || nums[start+i] == target) {
                return i;
            }
        }
        int mini = size;
        for(int i = 0; i < size; i++) {
            if(nums[i] == target) {
                mini = min(mini, abs(start-i));
            }
        }
        return mini;
    }
};
